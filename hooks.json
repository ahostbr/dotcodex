{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -m liteharness.hooks register",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python -m liteharness.hooks check",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -m liteharness.hooks check",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -m liteharness.hooks check",
            "timeout": 5
          }
        ]
      }
    ]
  }
}